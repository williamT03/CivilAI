# CivilAI backend runtime
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://civilai:civilai@postgres:5432/civilai
STRUCTURED_DATABASE_URL=postgresql+psycopg://civilai:civilai@postgres:5432/civilai
JWT_SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://civilai.willcloudlab.com
CORS_ALLOW_CREDENTIALS=true
MAX_UPLOAD_BYTES=52428800
MAX_REQUEST_BYTES=62914560
RATE_LIMIT_PER_MINUTE=120
FREE_MONTHLY_TOKEN_LIMIT=0
STANDARD_MONTHLY_TOKEN_LIMIT=0
PRO_MONTHLY_TOKEN_LIMIT=0
FREE_MONTHLY_MESSAGE_LIMIT=0
PRO_MONTHLY_MESSAGE_LIMIT=0

# AI routing
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=deepseek
AI_LOCAL_PROVIDER=ollama
AI_EMBEDDING_PROVIDER=openai
AI_BACKGROUND_PROVIDER=deepseek
AI_ENABLE_OLLAMA_FALLBACK=true
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3
DOCKER_OLLAMA_URL=http://host.docker.internal:11434
DOCKER_REQUIREMENTS_FILE=requirements-server.txt
BACKEND_HOST_PORT=8000
NGINX_HOST_PORT=8081

# Data services
REDIS_URL=redis://redis:6379/0
ASYNC_INGESTION_ENABLED=true
# Use qdrant in production. Use chroma for simple offline/local development.
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
CHROMA_PERSIST_DIRECTORY=backend/Data/chroma_db

# Cloudflare R2 / S3-compatible uploads
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIRECTORY=backend/Data/PDF

# Optional pricing override for usage_logs estimated_cost_usd.
# Values are dollars per 1M tokens. Set only when you want billing estimates.
AI_PRICE_OPENAI_GPT_4_1_MINI_INPUT_PER_M=0
AI_PRICE_OPENAI_GPT_4_1_MINI_OUTPUT_PER_M=0
AI_PRICE_OPENAI_TEXT_EMBEDDING_3_SMALL_EMBEDDING_PER_M=0
