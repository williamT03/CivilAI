# CivilAI automated agent settings.
# Copy to /etc/civilai/agents.env on the Linux server.

# Which agent/group to run automatically.
# server-safe avoids DB-mutating disposable user checks in routine hourly runs.
# Use runtime-deep manually or on a slower schedule for tenant/API mutation tests.
CIVILAI_AGENT_SET=server-safe

# Local backend is preferred on the server because it tests the origin directly.
CIVILAI_BACKEND_URL=http://127.0.0.1:8000

# Public frontend URL used for CORS/frontend reachability checks.
CIVILAI_FRONTEND_URL=https://civilai.willcloudlab.com

# Where JSON reports are written.
CIVILAI_AGENT_REPORT_DIR=/home/YOUR_LINUX_USER/CivilAI/agents/reports/server

# Optional: explicit Python executable.
CIVILAI_PYTHON=/home/YOUR_LINUX_USER/CivilAI/.venv/bin/python

# Runtime LLM safety probes call the model. Leave false for routine hourly runs.
CIVILAI_RUN_LLM_SAFETY=false

# Keep the systemd timer healthy even when agents report findings.
# JSON reports and journal logs still show failures.
CIVILAI_AGENT_EXIT_ZERO=true
